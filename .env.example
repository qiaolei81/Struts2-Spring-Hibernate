# =============================================================
# Production Environment Variables
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked REQUIRED
# 3. Never commit .env to source control
# =============================================================


# =============================================================
# MySQL
# =============================================================

# REQUIRED — password for the MySQL root account
# Used only for the Docker healthcheck and initial schema setup.
MYSQL_ROOT_PASSWORD=changeme_root

# Database name created on first container startup
MYSQL_DATABASE=system_db

# Application DB user — principle of least privilege
# The backend connects as this user, not root.
MYSQL_USER=appuser

# REQUIRED — password for the application DB user
MYSQL_PASSWORD=changeme_app


# =============================================================
# JWT Security
# =============================================================

# REQUIRED — HMAC-SHA512 signing secret for JWT tokens.
# Must be at least 32 characters (64+ recommended).
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_a_strong_secret_with_openssl_rand_base64_64

# Token lifetime in milliseconds (default: 86400000 = 24 hours)
JWT_EXPIRATION_MS=86400000


# =============================================================
# CORS
# =============================================================

# Comma-separated list of allowed origins (no trailing slash).
# Set to the public URL(s) where the frontend is served.
# Example for production: https://example.com
# Example for multiple origins: https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost


# =============================================================
# Network
# =============================================================

# Host port on which Nginx will listen (default: 80)
HTTP_PORT=80


# =============================================================
# JVM Tuning (optional)
# =============================================================

# Heap flags passed to the backend JVM at startup.
# Adjust Xmx to roughly 75 % of container memory limit.
JAVA_OPTS=-Xmx512m -Xms256m


# =============================================================
# Logging (optional)
# =============================================================

# Log level for com.rml.* packages (DEBUG | INFO | WARN | ERROR)
LOG_LEVEL=INFO
